{
  "manifest_version": 2,
  "name": "PyDM Bridge",
  "version": "1.0",
  "description": "Connecte votre navigateur à PyDM pour intercepter les téléchargements",
  "permissions": [
    "downloads",
    "webRequest",
    "webRequestBlocking",
    "storage",
    "cookies",
    "contextMenus",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
